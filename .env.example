# PostgreSQL (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/truongson"

# NextAuth — tạo secret ngẫu nhiên, ví dụ: openssl rand -base64 32
AUTH_SECRET=

# Docker Compose — seed & đăng nhập (định dạng .env: KEY=giá_trị, không cách quanh "=", có thể dùng ngoặc kép nếu có khoảng trắng):
# Không ghi các dòng dưới → seed dùng mặc định: admin@truongsonpremium.com / Admin123!
# ADMIN_EMAIL=admin@truongsonpremium.com
# ADMIN_PASSWORD=MatKhauCuaBan
# ADMIN_NAME=Ten hien thi

# Cảnh báo: nếu đặt CẢ ADMIN_EMAIL và ADMIN_PASSWORD, service web chỉ chấp nhận
# đúng cặp này khi đăng nhập (bỏ qua user trong DB). Chỉ đặt một trong hai thì
# vẫn đăng nhập bằng bảng AdminUser (sau khi seed).
